class camera:
    def camera_rolling(self):
        print("camera rolling")
class phone:
    def phone_calling(self):
        print("phone calling")
class smartphone(camera,phone):
    def smartphone(self):
        print("smartphone calling")
s=smartphone()
s.camera_rolling()
s.phone_calling()
s.smartphone()

class vehicle:
    def start(self):
        print("vehicle start")
class car(vehicle):
    def stop(self):
        print("car stop")
class electricbike(car):
    def charge(self):
        print("electricbike charging")
e=electricbike()
e.start()
e.stop()
e.charge()
