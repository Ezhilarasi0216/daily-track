class Emp:
    def __init__(self):
        self.id=16
        self.name="ezhil"
        self.salary=500
class Child(Emp):
    def show(self):
        print("ID:",self.id,"Name:",self.name,"Salary:",self.salary)
emp1=Child()
emp1.show()

